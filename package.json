{
  "name": "third-eye",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Third Eye — a production-grade screenshot/render API that can capture any website, including canvas-based apps (Flutter/CanvasKit, WebGL).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:api": "tsx watch src/entrypoints/api.ts",
    "dev:worker": "tsx watch src/entrypoints/worker.ts",
    "start:api": "node dist/entrypoints/api.js",
    "start:worker": "node dist/entrypoints/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "browsers:install": "playwright install --with-deps chromium",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/under-pressure": "^9.0.1",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.1",
    "generic-pool": "^3.9.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.8",
    "pino": "^9.5.0",
    "playwright": "^1.48.2",
    "prom-client": "^15.1.3",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
}
