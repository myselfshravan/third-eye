# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
# api | worker — set per process. Compose/Fly set this explicitly.
ROLE=api

# ─── HTTP ─────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
# Comma-separated origins, or * for any.
CORS_ORIGINS=*
# Max request body (bytes) — bulk payloads can be large.
BODY_LIMIT_BYTES=1048576

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated API keys. Format: key:plan  (plan ∈ free|pro|unlimited)
# e.g.  te_live_abc:pro,te_live_def:free
# Leave empty to disable auth (DEV ONLY).
API_KEYS=te_dev_local:unlimited
# Per-minute request quota per plan (overridden by key plan).
RATE_FREE_PER_MIN=10
RATE_PRO_PER_MIN=120
RATE_UNLIMITED_PER_MIN=100000

# ─── Redis (queue + rate-limit state) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Browser pool ─────────────────────────────────────────────────────────────
# Concurrent browser instances. Each ~150-400MB. Tune to host RAM.
BROWSER_POOL_SIZE=2
# Recycle a browser after this many captures (caps memory-leak growth).
BROWSER_MAX_USES=80
# Hard cap on a single capture (ms) before we abort the page.
CAPTURE_TIMEOUT_MS=30000
# Navigation timeout (ms).
NAV_TIMEOUT_MS=20000
# Headful for local debugging (true keeps a window; never in prod).
BROWSER_HEADLESS=true
# Enable software WebGL (SwiftShader) so Flutter/CanvasKit/WebGL render in headless.
BROWSER_ENABLE_WEBGL=true
# Use Patchright's patched Chromium to defeat headless/automation bot detection.
STEALTH=true
# '' = bundled Chromium; 'chrome'/'msedge' to drive a system browser (real TLS fp).
BROWSER_CHANNEL=
# Optional egress proxy for the hardest (Akamai/DataDome) targets. e.g.
# http://user:pass@host:port  — empty = direct.
PROXY_URL=

# ─── Extraction (product images + structured data) ────────────────────────────
# Max product images returned per page.
EXTRACT_MAX_IMAGES=12
# Re-host extracted images in our own storage (requires STORAGE_DRIVER != none).
EXTRACT_DOWNLOAD_IMAGES=false

# ─── Worker ───────────────────────────────────────────────────────────────────
# Jobs processed in parallel per worker process. Keep <= BROWSER_POOL_SIZE.
WORKER_CONCURRENCY=2
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
# Completed/failed job retention (seconds) in Redis.
JOB_TTL_SECONDS=86400

# ─── Storage (pluggable: none | s3 | local) ───────────────────────────────────
# none  → return binary/base64 only (no uploads)
# s3    → Cloudflare R2 / AWS S3 / MinIO / B2 (set S3_* below)
# local → write to LOCAL_STORAGE_DIR on disk
STORAGE_DRIVER=none

# -- s3 driver --
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=third-eye
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base used to build returned URLs (your CDN/R2 public domain).
# If empty, the API returns a presigned URL instead.
S3_PUBLIC_BASE_URL=
S3_PRESIGN_TTL_SECONDS=3600

# -- local driver --
LOCAL_STORAGE_DIR=captures
# URL that maps to LOCAL_STORAGE_DIR (served by a CDN/sidecar). Empty → file://.
LOCAL_PUBLIC_BASE_URL=

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_BULK_URLS=100
# Largest viewport we allow (guards memory). width x height.
MAX_VIEWPORT_WIDTH=3840
MAX_VIEWPORT_HEIGHT=4320
