# Copy to `.env` on the server and fill in. Used by docker-compose.prod.yml.
# NEVER commit the real .env (it's gitignored).

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Auth — generate strong keys! ────────────────────────────────────────────
# Format: key:plan (plan ∈ free|pro|unlimited), comma-separated.
# Generate one with:  openssl rand -hex 24  →  te_live_<hex>
API_KEYS=te_live_REPLACE_ME:unlimited

# Per-plan request quota (requests/minute).
RATE_FREE_PER_MIN=10
RATE_PRO_PER_MIN=120
RATE_UNLIMITED_PER_MIN=100000

# ─── Browser pool / worker — tune to the box's RAM ───────────────────────────
# Rule of thumb: each browser ≈ 150-400MB. Keep WORKER_CONCURRENCY ≤ POOL_SIZE.
# A 4-core / 8GB box comfortably runs POOL_SIZE=4, CONCURRENCY=4 per worker.
BROWSER_POOL_SIZE=4
WORKER_CONCURRENCY=4
BROWSER_MAX_USES=80
CAPTURE_TIMEOUT_MS=45000
NAV_TIMEOUT_MS=30000
BROWSER_HEADLESS=true
BROWSER_ENABLE_WEBGL=true
# Stealth (Patchright) on by default — defeats headless/automation bot detection.
STEALTH=true
BROWSER_CHANNEL=
# Egress proxy for the hardest Akamai/DataDome targets (empty = direct).
PROXY_URL=

# Extraction
EXTRACT_MAX_IMAGES=12
EXTRACT_DOWNLOAD_IMAGES=false

JOB_ATTEMPTS=3
JOB_BACKOFF_MS=5000
JOB_TTL_SECONDS=86400

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Zero Trust → Networks → Tunnels → create a tunnel → copy its token.
# Route a public hostname (e.g. shots.yourdomain.com) to service http://api:8080.
TUNNEL_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN

# ─── Storage (pluggable: none | s3 | local) ──────────────────────────────────
# With driver=none, async results inline as base64 in Redis — OK to start, but
# use s3 (Cloudflare R2) for real volume so Redis stays lean.
STORAGE_DRIVER=none
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=third-eye
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PRESIGN_TTL_SECONDS=3600
LOCAL_STORAGE_DIR=captures
LOCAL_PUBLIC_BASE_URL=
